# Database Configuration
DATABASE_URL=postgresql://quanttrack_user:your_secure_password@localhost:5432/quanttrack_db
DB_ECHO=False

# JWT Configuration
SECRET_KEY=your_super_secret_key_change_in_production_at_least_32_characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
APP_NAME=QuantTrack
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ML Model Configuration
ML_MODEL_PATH=./backend/app/ml/model_storage/
RETRAIN_INTERVAL_DAYS=7

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/quanttrack.log
